@model SOEEApp.Models.ViewModels.PaymentReconciliationViewModel

@{
    ViewBag.Title = "Reconcile Payment";
}

<h2>Reconcile Payment</h2>

<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="card card-body shadow-sm"><strong>Project</strong><span>@Model.ProjectName</span></div></div>
    <div class="col-md-3"><div class="card card-body shadow-sm"><strong>Customer</strong><span>@Model.CustomerName</span></div></div>
    <div class="col-md-3"><div class="card card-body shadow-sm"><strong>Total Received</strong><span>@Model.TotalReceived.ToString("N2")</span></div></div>
    <div class="col-md-3"><div class="card card-body shadow-sm"><strong>Outstanding</strong><span>@Model.OutstandingAmount.ToString("N2")</span></div></div>
</div>

@using (Html.BeginForm("Reconcile", "Payments", FormMethod.Post, new { @class = "card card-body shadow-sm mb-3" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.SOEEID)
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="row g-3">
        <div class="col-md-4">
            @Html.LabelFor(m => m.VoucherNumber)
            @Html.TextBoxFor(m => m.VoucherNumber, new { @class = "form-control" })
        </div>
        <div class="col-md-4">
            @Html.LabelFor(m => m.VoucherDate)
            @Html.TextBoxFor(m => m.VoucherDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
        </div>
        <div class="col-md-4">
            <label>Grand Total</label>
            <input type="text" class="form-control" readonly value="@Model.GrandTotal.ToString("N2")" />
        </div>
        <div class="col-md-12">
            @Html.LabelFor(m => m.Remarks)
            @Html.TextAreaFor(m => m.Remarks, 3, 20, new { @class = "form-control" })
        </div>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button type="submit" class="btn btn-primary">Confirm Reconciliation</button>
        <a href="@Url.Action("Details", "SOEE", new { id = Model.SOEEID })" class="btn btn-outline-secondary">Cancel</a>
    </div>
}

<div class="card card-body shadow-sm">
    <h4>Recorded Payments</h4>
    <table class="table table-bordered mb-0">
        <thead>
            <tr>
                <th>Date</th>
                <th>UTR</th>
                <th>Mode</th>
                <th>Amount</th>
                <th>Confirmed By</th>
                <th>Reconciled</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var payment in Model.Payments)
            {
                <tr>
                    <td>@payment.PaymentDate.ToString("dd-MMM-yyyy")</td>
                    <td>@payment.UTRNo</td>
                    <td>@payment.Mode</td>
                    <td>@payment.AmountReceived.ToString("N2")</td>
                    <td>@payment.ConfirmedBy</td>
                    <td>@(payment.IsReconciled ? "Yes" : "No")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
