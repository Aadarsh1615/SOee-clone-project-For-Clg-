@model SOEEApp.Models.ReceiptVoucher

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Receipt Voucher - @Model.VoucherNumber</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 32px; }
        .box { border: 1px solid #ddd; padding: 24px; }
        .row { margin-bottom: 10px; }
        strong { display: inline-block; width: 160px; }
    </style>
</head>
<body onload="window.print()">
    <div class="box">
        <h1>Receipt Voucher</h1>
        <div class="row"><strong>Voucher No.:</strong> @Model.VoucherNumber</div>
        <div class="row"><strong>Voucher Date:</strong> @Model.VoucherDate.ToString("dd-MMM-yyyy")</div>
        <div class="row"><strong>SOEE ID:</strong> @Model.SOEEID</div>
        <div class="row"><strong>Project:</strong> @(Model.SOEE != null && Model.SOEE.Project != null ? Model.SOEE.Project.Name : "")</div>
        <div class="row"><strong>Customer:</strong> @(Model.SOEE != null && Model.SOEE.Customer != null ? Model.SOEE.Customer.CustomerName : "")</div>
        <div class="row"><strong>Amount:</strong> @Model.Amount.ToString("N2")</div>
        <div class="row"><strong>Status:</strong> @Model.Status</div>
        <div class="row"><strong>Generated By:</strong> @Model.GeneratedBy</div>
        <div class="row"><strong>Generated On:</strong> @Model.GeneratedOn.ToString("dd-MMM-yyyy HH:mm")</div>
        <div class="row"><strong>Remarks:</strong> @Model.Remarks</div>
    </div>
</body>
</html>
