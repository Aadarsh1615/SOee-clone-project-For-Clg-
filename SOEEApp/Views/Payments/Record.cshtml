@model SOEEApp.Models.ViewModels.PaymentEntryViewModel

@{
    ViewBag.Title = "Record Payment";
}

<h2>Record Payment</h2>

<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="card card-body shadow-sm"><strong>Project</strong><span>@Model.ProjectName</span></div></div>
    <div class="col-md-3"><div class="card card-body shadow-sm"><strong>Customer</strong><span>@Model.CustomerName</span></div></div>
    <div class="col-md-3"><div class="card card-body shadow-sm"><strong>Grand Total</strong><span>@Model.SOEEGrandTotal.ToString("N2")</span></div></div>
    <div class="col-md-3"><div class="card card-body shadow-sm"><strong>Outstanding</strong><span>@Model.OutstandingAmount.ToString("N2")</span></div></div>
</div>

@using (Html.BeginForm("Record", "Payments", FormMethod.Post, new { @class = "card card-body shadow-sm mb-3" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.SOEEID)
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="row g-3">
        <div class="col-md-3">
            @Html.LabelFor(m => m.UTRNo)
            @Html.TextBoxFor(m => m.UTRNo, new { @class = "form-control" })
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.AmountReceived)
            @Html.TextBoxFor(m => m.AmountReceived, new { @class = "form-control", type = "number", step = "0.01" })
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.PaymentDate)
            @Html.TextBoxFor(m => m.PaymentDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.Mode)
            @Html.EnumDropDownListFor(m => m.Mode, new { @class = "form-control" })
        </div>
        <div class="col-md-12">
            @Html.LabelFor(m => m.Remarks)
            @Html.TextAreaFor(m => m.Remarks, 3, 20, new { @class = "form-control" })
        </div>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button type="submit" class="btn btn-success">Save Payment</button>
        <a href="@Url.Action("Details", "SOEE", new { id = Model.SOEEID })" class="btn btn-outline-secondary">Cancel</a>
    </div>
}

<div class="row g-3">
    <div class="col-md-8">
        <div class="card card-body shadow-sm">
            <h4>Payment History</h4>
            @if (Model.History.Any())
            {
                <table class="table table-bordered mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>UTR</th>
                            <th>Mode</th>
                            <th>Amount</th>
                            <th>Reconciled</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var payment in Model.History)
                        {
                            <tr>
                                <td>@payment.PaymentDate.ToString("dd-MMM-yyyy")</td>
                                <td>@payment.UTRNo</td>
                                <td>@payment.Mode</td>
                                <td>@payment.AmountReceived.ToString("N2")</td>
                                <td>@(payment.IsReconciled ? "Yes" : "No")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted mb-0">No payment recorded yet.</p>
            }
        </div>
    </div>

    <div class="col-md-4">
        <div class="card card-body shadow-sm">
            <h4>Receipt Voucher</h4>
            @if (Model.ReceiptVoucher != null)
            {
                <div><strong>No.:</strong> @Model.ReceiptVoucher.VoucherNumber</div>
                <div><strong>Date:</strong> @Model.ReceiptVoucher.VoucherDate.ToString("dd-MMM-yyyy")</div>
                <div><strong>Status:</strong> @Model.ReceiptVoucher.Status</div>
                <div><strong>Amount:</strong> @Model.ReceiptVoucher.Amount.ToString("N2")</div>
            }
            else
            {
                <p class="text-muted mb-0">Voucher will be generated automatically and updated on reconciliation.</p>
            }
        </div>
    </div>
</div>
