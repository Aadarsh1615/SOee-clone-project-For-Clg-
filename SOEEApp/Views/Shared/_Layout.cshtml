<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - FinTrack</title>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
        var hideLayout = currentController == "Account" && (currentAction == "Login" || currentAction == "Register");
    }
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <!-- Bootstrap 5 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    
    @Styles.Render("~/Content/css")
</head>
<body class="app-root">
    @if (!hideLayout)
    {
        <header class="app-nav">
            <div class="container">
                <div class="d-flex align-items-center justify-content-center flex-fill">
                    <a class="app-brand fs-3 fw-bold text-primary" href="/Home/Index">FinTrack</a>
                </div>
                <nav class="flex-fill">
                    <ul class="nav-list justify-content-end">
                        @if (User.IsInRole("OIC"))
                        {
                            <li class="nav-item">@Html.ActionLink("My SOEE", "Index", "SOEE", null, new { @class = "nav-link" })</li>
                            <li class="nav-item">@Html.ActionLink("Create SOEE", "Create", "SOEE", null, new { @class = "nav-link" })</li>
                            <li class="nav-item">@Html.ActionLink("Projects", "Index", "Projects", null, new { @class = "nav-link" })</li>
                            <li class="nav-item">@Html.ActionLink("Cost Slabs", "Index", "ServiceCostSlabs", null, new { @class = "nav-link" })</li>
                            <li class="nav-item">@Html.ActionLink("Client Details", "Index", "Customers", null, new { @class = "nav-link" })</li>
                            <li class="nav-item">@Html.ActionLink("Mapping", "Index", "ProjectServiceMaps", null, new { @class = "nav-link" })</li>
                        }
                        @if (User.IsInRole("FinanceManager")) { <li class="nav-item">@Html.ActionLink("Pending FM", "PendingFM", "SOEE", null, new { @class = "nav-link" })</li> }
                        @if (User.IsInRole("FinanceDirector")) { <li class="nav-item">@Html.ActionLink("Pending FD", "PendingFD", "SOEE", null, new { @class = "nav-link" })</li> }
                        @if (User.IsInRole("Cashier")) { <li class="nav-item">@Html.ActionLink("Payments", "Index", "Payments", null, new { @class = "nav-link" })</li> }
                        @if (User.IsInRole("Client")) { <li class="nav-item">@Html.ActionLink("My SOEEs", "MySOEE", "SOEE", null, new { @class = "nav-link" })</li> }
                    </ul>
                </nav>
                <div style="display:flex;gap:0.6rem; align-items:center;">
                    @Html.Partial("_LoginPartial")
                </div>
            </div>
        </header>
    }

    <div class="container-fluid body-content mt-5 pt-4 px-3 px-md-4">
        <main role="main" class="pb-4">
            @if (hideLayout)
            {
                <div class="auth-page-wrap d-flex justify-content-center align-items-center">
                    <div class="auth-card p-5 rounded shadow-lg bg-white">
                        @RenderBody()
                    </div>
                </div>
            }
            else
            {
                <div class="content-frame rounded-3 p-3 p-md-4 shadow-sm bg-white">
                    @RenderBody()
                </div>
            }
        </main>
    </div>


    @if (!hideLayout)
    {
        <footer class="footer mt-5 pt-3 pb-2">
            <div class="container text-center small text-muted">
                &copy; @DateTime.Now.Year - FinTrack · Designed for modern workflow teams
            </div>
        </footer>
    }

    <script src="@Url.Content("~/Scripts/jquery-1.10.2.min.js")"></script>
    <!-- Bootstrap 5 Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
    
    @RenderSection("scripts", required: false)
</body>
</html>
