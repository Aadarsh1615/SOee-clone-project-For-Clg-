@model SOEEApp.Models.ServiceCostSlab

@{
    ViewBag.Title = "Edit Slab";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white">
                <h4 class="mb-0 text-primary">Edit Slab</h4>
            </div>
            <div class="card-body p-4">
                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-danger alert alert-danger" })
                    @Html.HiddenFor(model => model.Id)

                    <div class="mb-3">
                        @Html.LabelFor(m => m.MinAmount, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.MinAmount, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.MinAmount, "", new { @class = "text-danger small" })
                    </div>

                    <div class="mb-3">
                        @Html.LabelFor(m => m.MaxAmount, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.MaxAmount, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.MaxAmount, "", new { @class = "text-danger small" })
                    </div>

                    @Html.HiddenFor(model => model.IsActive)

                    <div class="d-grid gap-2 mt-4">
                        <input type="submit" value="Save Changes" class="btn btn-primary" />
                        @Html.ActionLink("Cancel", "Index", null, new { @class = "btn btn-light text-secondary" })
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
