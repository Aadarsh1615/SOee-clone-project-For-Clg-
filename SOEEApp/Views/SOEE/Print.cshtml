@model SOEEApp.Models.ViewModels.SOEECreateViewModel

@{
    Layout = null;
    var received = Model.Payments.Sum(p => p.AmountReceived);
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>SOEE Print - @Model.SOEEID</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 24px; color: #222; }
        h1, h2, h3 { margin-bottom: 8px; }
        .meta { margin-bottom: 18px; }
        .meta div { margin-bottom: 4px; }
        table { width: 100%; border-collapse: collapse; margin-top: 12px; }
        th, td { border: 1px solid #ccc; padding: 8px; font-size: 12px; }
        th { background: #f4f4f4; text-align: left; }
        .totals { margin-top: 18px; width: 320px; margin-left: auto; }
        .totals td { font-weight: bold; }
    </style>
</head>
<body onload="window.print()">
    <h1>FinTrack</h1>
    <h2>Statement of Estimated Expenses</h2>

    <div class="meta">
        <div><strong>SOEE ID:</strong> @Model.SOEEID</div>
        <div><strong>Project:</strong> @(Model.Project != null ? Model.Project.Name : "")</div>
        <div><strong>Customer:</strong> @(Model.Customer != null ? Model.Customer.CustomerName : "")</div>
        <div><strong>Reference No.:</strong> @Model.ReferenceNo</div>
        <div><strong>Date:</strong> @Model.SOEERaiseDate.ToString("dd-MMM-yyyy")</div>
        <div><strong>Status:</strong> @Model.Status</div>
        <div><strong>E-Signed:</strong> @(Model.IsESigned ? "Yes" : "No")</div>
        <div><strong>Dispatch Email:</strong> @Model.DispatchEmail</div>
    </div>

    <table>
        <thead>
            <tr>
                <th>Description</th>
                <th>Service Type</th>
                <th>Unit</th>
                <th>Quantity</th>
                <th>Unit Price</th>
                <th>Subtotal</th>
                <th>Service %</th>
                <th>Service Charge</th>
                <th>CGST</th>
                <th>SGST</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.DescriptionOfWork</td>
                    <td>@item.ServiceTypeName</td>
                    <td>@item.Unit</td>
                    <td>@item.Quantity</td>
                    <td>@item.UnitPrice.ToString("N2")</td>
                    <td>@item.SubTotal.ToString("N2")</td>
                    <td>@item.ServiceChargePercent.ToString("N2")</td>
                    <td>@item.ServiceCharge.ToString("N2")</td>
                    <td>@item.CGST.ToString("N2")</td>
                    <td>@item.SGST.ToString("N2")</td>
                    <td>@item.Total.ToString("N2")</td>
                </tr>
            }
        </tbody>
    </table>

    <table class="totals">
        <tr><td>Total Basic</td><td>@Model.TotalBasicAmount.ToString("N2")</td></tr>
        <tr><td>Total Service Charge</td><td>@Model.TotalServiceCharge.ToString("N2")</td></tr>
        <tr><td>Total Tax</td><td>@Model.TotalTaxAmount.ToString("N2")</td></tr>
        <tr><td>Grand Total</td><td>@Model.GrandTotal.ToString("N2")</td></tr>
        <tr><td>Received</td><td>@received.ToString("N2")</td></tr>
    </table>
</body>
</html>
