@using SOEEApp.Models
@model IEnumerable<SOEEApp.Models.SOEE>

@{
    ViewBag.Title = "SOEE List";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <div>
        <h2 class="mb-1">SOEE Register</h2>
        <p class="text-muted mb-0">Project-wise list with workflow, payment and closure status.</p>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        @if (User.IsInRole("OIC"))
        {
            <a href="@Url.Action("Create")" class="btn btn-primary">Create SOEE</a>
        }
        <a href="@Url.Action("ExportCsv", "SOEE", new { projectId = Request["projectId"], status = ViewBag.SelectedStatus })" class="btn btn-outline-success">Export Excel</a>
        <a href="@Url.Action("Index", "Reports")" class="btn btn-outline-secondary">Reports</a>
    </div>
</div>

@using (Html.BeginForm("Index", "SOEE", FormMethod.Get, new { @class = "card card-body shadow-sm mb-3" }))
{
    <div class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Project</label>
            @Html.DropDownList("projectId", ViewBag.Projects as SelectList, "All Projects", new { @class = "form-control" })
        </div>
        <div class="col-md-4">
            <label class="form-label">Status</label>
            <select name="status" class="form-control">
                <option value="">All Statuses</option>
                @foreach (SOEEStatus status in Enum.GetValues(typeof(SOEEStatus)))
                {
                    <option value="@status" @(string.Equals((string)ViewBag.SelectedStatus, status.ToString(), StringComparison.OrdinalIgnoreCase) ? "selected" : "")>@status</option>
                }
            </select>
        </div>
        <div class="col-md-4 d-flex gap-2">
            <button type="submit" class="btn btn-dark">Apply</button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Reset</a>
        </div>
    </div>
}

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>SOEE ID</th>
                    <th>Project</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Received</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var received = item.Payments != null ? item.Payments.Sum(p => p.AmountReceived) : 0m;
                    <tr>
                        <td>@item.SOEEID</td>
                        <td>@(item.Project != null ? item.Project.Name : "")</td>
                        <td>@(item.Customer != null ? item.Customer.CustomerName : "")</td>
                        <td>@item.SOEERaiseDate.ToString("dd-MMM-yyyy")</td>
                        <td>@item.GrandTotal.ToString("N2")</td>
                        <td>@received.ToString("N2")</td>
                        <td><span class="badge bg-secondary">@item.Status</span></td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2 flex-wrap">
                                <a href="@Url.Action("Details", new { id = item.SOEEID })" class="btn btn-sm btn-outline-info">View</a>
                                <a href="@Url.Action("Print", new { id = item.SOEEID })" class="btn btn-sm btn-outline-dark" target="_blank">Print</a>

                                @if (User.IsInRole("OIC") && (item.Status == SOEEStatus.Draft || item.Status == SOEEStatus.NeedCorrection))
                                {
                                    <a href="@Url.Action("Edit", new { id = item.SOEEID })" class="btn btn-sm btn-outline-warning">Edit</a>
                                    using (Html.BeginForm("Submit", "SOEE", FormMethod.Post, new { style = "display:inline;" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        @Html.Hidden("id", item.SOEEID)
                                        <button class="btn btn-sm btn-success js-submit" data-id="@item.SOEEID" type="submit">Submit</button>
                                    }
                                }

                                @if (User.IsInRole("FinanceManager") && item.Status == SOEEStatus.Submitted)
                                {
                                    using (Html.BeginForm("ApproveByFM", "SOEE", FormMethod.Post, new { style = "display:inline;" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        @Html.Hidden("id", item.SOEEID)
                                        <button class="btn btn-sm btn-outline-primary js-approve" data-id="@item.SOEEID" type="submit">Approve</button>
                                    }
                                    using (Html.BeginForm("NeedCorrectionByFM", "SOEE", FormMethod.Post, new { style = "display:inline;" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        @Html.Hidden("id", item.SOEEID)
                                        <button class="btn btn-sm btn-outline-warning js-correction" data-id="@item.SOEEID" type="submit">Correction</button>
                                    }
                                }

                                @if (User.IsInRole("FinanceDirector") && item.Status == SOEEStatus.Approved)
                                {
                                    using (Html.BeginForm("ApproveByFD", "SOEE", FormMethod.Post, new { style = "display:inline;" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        @Html.Hidden("id", item.SOEEID)
                                        <button class="btn btn-sm btn-success js-final-approve" data-id="@item.SOEEID" type="submit">Dispatch</button>
                                    }
                                }

                                @if (User.IsInRole("Client") && (item.Status == SOEEStatus.Dispatched || item.Status == SOEEStatus.ErrorInPayment))
                                {
                                    <button class="btn btn-sm btn-outline-warning js-partial" data-id="@item.SOEEID" type="button">Partial</button>
                                    <button class="btn btn-sm btn-outline-success js-full" data-id="@item.SOEEID" type="button">Full</button>
                                    <button class="btn btn-sm btn-outline-danger js-reject" data-id="@item.SOEEID" type="button">Reject</button>
                                }

                                @if (User.IsInRole("Cashier") && (item.Status == SOEEStatus.Reconciled || item.Status == SOEEStatus.PartiallyPaid || item.Status == SOEEStatus.FullyPaid || item.Status == SOEEStatus.ErrorInPayment))
                                {
                                    <a href="@Url.Action("Record", "Payments", new { soeeId = item.SOEEID })" class="btn btn-sm btn-outline-primary">Record Payment</a>
                                    <a href="@Url.Action("Reconcile", "Payments", new { soeeId = item.SOEEID })" class="btn btn-sm btn-outline-primary">Reconcile</a>
                                    <button class="btn btn-sm btn-outline-danger js-error-payment" data-id="@item.SOEEID" type="button">Error</button>
                                }

                                @if (User.IsInRole("OIC") && item.Status == SOEEStatus.Reconciled)
                                {
                                    <button class="btn btn-sm btn-success js-close" data-id="@item.SOEEID" type="button">Close</button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
}

@section Scripts {
    <script>
        function updateSOEE(url, id) {
            var token = $('input[name="__RequestVerificationToken"]').first().val();

            $.ajax({
                url: url,
                type: "POST",
                data: {
                    __RequestVerificationToken: token,
                    id: id
                },
                success: function (res) {
                    if (res.success) {
                        window.location.reload();
                    }
                },
                error: function (xhr) {
                    alert("Action failed: " + xhr.status);
                }
            });
        }

        $(document).on("click", ".js-submit", function (e) {
            e.preventDefault();
            updateSOEE("@Url.Action("SubmitAjax", "SOEE")", $(this).data("id"));
        });

        $(document).on("click", ".js-approve", function (e) {
            e.preventDefault();
            updateSOEE("@Url.Action("ApproveByFMAjax", "SOEE")", $(this).data("id"));
        });

        $(document).on("click", ".js-correction", function (e) {
            e.preventDefault();
            updateSOEE("@Url.Action("NeedCorrectionByFMAjax", "SOEE")", $(this).data("id"));
        });

        $(document).on("click", ".js-final-approve", function (e) {
            e.preventDefault();
            updateSOEE("@Url.Action("ApproveByFDAjax", "SOEE")", $(this).data("id"));
        });

        $(document).on("click", ".js-partial", function () {
            updateSOEE("@Url.Action("MarkPartiallyPaidAjax", "SOEE")", $(this).data("id"));
        });

        $(document).on("click", ".js-full", function () {
            updateSOEE("@Url.Action("MarkFullyPaidAjax", "SOEE")", $(this).data("id"));
        });

        $(document).on("click", ".js-reject", function () {
            updateSOEE("@Url.Action("RejectByClientAjax", "SOEE")", $(this).data("id"));
        });

        $(document).on("click", ".js-error-payment", function () {
            updateSOEE("@Url.Action("ErrorInPaymentAjax", "SOEE")", $(this).data("id"));
        });

        $(document).on("click", ".js-close", function () {
            updateSOEE("@Url.Action("CloseAjax", "SOEE")", $(this).data("id"));
        });
    </script>
}
