@model SOEEApp.Models.ViewModels.SOEECreateViewModel

@{
    ViewBag.Title = "Create SOEE";
    var serviceTypes = ViewBag.ServiceTypes as List<SOEEApp.Models.ServiceType> ?? new List<SOEEApp.Models.ServiceType>();
}

<h2>Create SOEE</h2>

@using (Html.BeginForm("Create", "SOEE", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="card card-body shadow-sm mb-3">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <h4 class="mb-0">Header Details</h4>
            <button type="button" id="loadPrevious" class="btn btn-outline-secondary">Autofill From Previous SOEE</button>
        </div>

        <div class="alert alert-info">
            Previous SOEE ID: <strong id="previousSoeeLabel">@(Model.PrevSOEEID.HasValue ? Model.PrevSOEEID.ToString() : "Not available")</strong>
            |
            Previous Balance: <strong id="previousBalanceLabel">@Model.PreviousSOEEBalance.ToString("N2")</strong>
        </div>

        @Html.HiddenFor(m => m.PrevSOEEID, new { id = "PrevSOEEID" })
        @Html.HiddenFor(m => m.PreviousSOEEBalance, new { id = "PreviousSOEEBalance" })

        <div class="row g-3">
            <div class="col-md-4">
                @Html.LabelFor(m => m.ProjectID)
                @Html.DropDownListFor(m => m.ProjectID, ViewBag.Projects as SelectList, "Select Project", new { @class = "form-control", id = "projectSelect" })
            </div>
            <div class="col-md-4">
                @Html.LabelFor(m => m.CustomerID)
                @Html.DropDownListFor(m => m.CustomerID, ViewBag.Customers as SelectList, "Select Customer", new { @class = "form-control" })
            </div>
            <div class="col-md-4">
                @Html.LabelFor(m => m.ReferenceNo)
                @Html.TextBoxFor(m => m.ReferenceNo, new { @class = "form-control", id = "ReferenceNo" })
            </div>
            <div class="col-md-4">
                @Html.LabelFor(m => m.MarkTo)
                @Html.TextBoxFor(m => m.MarkTo, new { @class = "form-control", id = "MarkTo" })
            </div>
            <div class="col-md-4">
                @Html.LabelFor(m => m.Subject)
                @Html.TextBoxFor(m => m.Subject, new { @class = "form-control", id = "Subject" })
            </div>
            <div class="col-md-4">
                @Html.LabelFor(m => m.Reference)
                @Html.TextBoxFor(m => m.Reference, new { @class = "form-control", id = "Reference" })
            </div>
            <div class="col-md-4">
                @Html.LabelFor(m => m.SOEERaiseDate, "SOEE Raised Date")
                @Html.TextBoxFor(m => m.SOEERaiseDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
            </div>
            <div class="col-md-8">
                @Html.LabelFor(m => m.Content, "Description / Note")
                @Html.TextAreaFor(m => m.Content, 3, 20, new { @class = "form-control", id = "Content" })
            </div>
        </div>
    </div>

    <div class="card card-body shadow-sm mb-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">Service Entry Items</h4>
            <button type="button" id="addRow" class="btn btn-primary">Add Service Item</button>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered" id="serviceTable">
                <thead>
                    <tr>
                        <th>Description of Work</th>
                        <th>Service Type</th>
                        <th>Unit</th>
                        <th>Quantity</th>
                        <th>Unit Price</th>
                        <th>Subtotal</th>
                        <th>Service Charge</th>
                        <th>CGST</th>
                        <th>SGST</th>
                        <th>Total</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="serviceBody"></tbody>
            </table>
        </div>
    </div>

    <div class="card card-body shadow-sm mb-3">
        <div class="row g-3">
            <div class="col-md-3">
                <label>Total Basic</label>
                <input type="text" id="TotalBasicAmount" class="form-control" readonly value="@Model.TotalBasicAmount.ToString("0.00")" />
            </div>
            <div class="col-md-3">
                <label>Total Service Charges</label>
                <input type="text" id="TotalServiceCharge" class="form-control" readonly value="@Model.TotalServiceCharge.ToString("0.00")" />
            </div>
            <div class="col-md-3">
                <label>Total Tax Amount</label>
                <input type="text" id="TotalTaxAmount" class="form-control" readonly value="@Model.TotalTaxAmount.ToString("0.00")" />
            </div>
            <div class="col-md-3">
                <label>Grand Total</label>
                <input type="text" id="GrandTotal" class="form-control" readonly value="@Model.GrandTotal.ToString("0.00")" />
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-success">Save Draft</button>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Cancel</a>
    </div>
}

@section Scripts {
    <script>
        var rowIndex = 0;

        function getServiceOptions(selectedId) {
            var html = '<option value="">Select</option>';
            @foreach (var s in serviceTypes)
            {
                @:html += '<option value="@s.ServiceTypeID">@s.ServiceName</option>';
            }
            return html.replace('value="' + selectedId + '"', 'value="' + selectedId + '" selected="selected"');
        }

        function buildRow(data) {
            data = data || {};
            var row = '<tr>' +
                '<td><input type="hidden" name="Items[' + rowIndex + '].SOEEItemID" value="0" />' +
                '<input type="hidden" name="Items[' + rowIndex + '].IsDeleted" class="isDeleted" value="false" />' +
                '<input type="text" name="Items[' + rowIndex + '].DescriptionOfWork" class="form-control description" value="' + (data.descriptionOfWork || '') + '" required /></td>' +
                '<td><select name="Items[' + rowIndex + '].ServiceTypeID" class="form-control serviceTypeDropdown">' + getServiceOptions(data.serviceTypeID || '') + '</select></td>' +
                '<td><input type="number" step="0.01" name="Items[' + rowIndex + '].Unit" class="form-control unit" value="' + (data.unit || '') + '" /></td>' +
                '<td><input type="number" step="0.01" name="Items[' + rowIndex + '].Quantity" class="form-control qty" value="' + (data.quantity || '') + '" /></td>' +
                '<td><input type="number" step="0.01" name="Items[' + rowIndex + '].UnitPrice" class="form-control unitPrice" value="' + (data.unitPrice || '') + '" /></td>' +
                '<td><input type="text" name="Items[' + rowIndex + '].SubTotal" class="form-control subTotal" readonly /></td>' +
                '<td><input type="text" name="Items[' + rowIndex + '].ServiceCharge" class="form-control serviceCharge" readonly /></td>' +
                '<td><input type="text" name="Items[' + rowIndex + '].CGST" class="form-control cgst" readonly /></td>' +
                '<td><input type="text" name="Items[' + rowIndex + '].SGST" class="form-control sgst" readonly /></td>' +
                '<td><input type="text" name="Items[' + rowIndex + '].Total" class="form-control total" readonly /></td>' +
                '<td><button type="button" class="btn btn-outline-danger removeRow">X</button></td>' +
                '</tr>';

            rowIndex += 1;
            return row;
        }

        function updateTotals() {
            var basic = 0;
            var service = 0;
            var tax = 0;
            var total = 0;

            $('#serviceBody tr').each(function () {
                if ($(this).find('.isDeleted').val() === 'true') {
                    return;
                }

                basic += parseFloat($(this).find('.subTotal').val()) || 0;
                service += parseFloat($(this).find('.serviceCharge').val()) || 0;
                tax += (parseFloat($(this).find('.cgst').val()) || 0) + (parseFloat($(this).find('.sgst').val()) || 0);
                total += parseFloat($(this).find('.total').val()) || 0;
            });

            $('#TotalBasicAmount').val(basic.toFixed(2));
            $('#TotalServiceCharge').val(service.toFixed(2));
            $('#TotalTaxAmount').val(tax.toFixed(2));
            $('#GrandTotal').val(total.toFixed(2));
        }

        function calculateRow(row) {
            var unit = parseFloat(row.find('.unit').val()) || 0;
            var qty = parseFloat(row.find('.qty').val()) || 0;
            var unitPrice = parseFloat(row.find('.unitPrice').val()) || 0;
            var subtotal = unit * qty * unitPrice;
            row.find('.subTotal').val(subtotal.toFixed(2));

            var serviceTypeId = row.find('.serviceTypeDropdown').val();
            var projectId = $('#projectSelect').val();

            if (!serviceTypeId || !projectId || subtotal <= 0) {
                row.find('.serviceCharge, .cgst, .sgst, .total').val('');
                updateTotals();
                return;
            }

            $.post('@Url.Action("GetServiceChargePercent", "SOEE")', {
                serviceTypeId: serviceTypeId,
                subtotal: subtotal,
                projectId: projectId
            }).done(function (data) {
                var percent = data.percentage || 0;
                var serviceCharge = subtotal * percent / 100;
                var taxable = subtotal + serviceCharge;
                var cgst = taxable * 0.09;
                var sgst = taxable * 0.09;
                var total = taxable + cgst + sgst;

                row.find('.serviceCharge').val(serviceCharge.toFixed(2));
                row.find('.cgst').val(cgst.toFixed(2));
                row.find('.sgst').val(sgst.toFixed(2));
                row.find('.total').val(total.toFixed(2));
                updateTotals();
            });
        }

        function bindRowEvents() {
            $(document).off('input change', '.unit, .qty, .unitPrice, .serviceTypeDropdown');
            $(document).on('input change', '.unit, .qty, .unitPrice, .serviceTypeDropdown', function () {
                calculateRow($(this).closest('tr'));
            });
        }

        function loadServicesForProject() {
            var pid = $('#projectSelect').val();
            $.getJSON('@Url.Action("GetServicesForProject", "SOEE")', { projectId: pid }, function (data) {
                $('.serviceTypeDropdown').each(function () {
                    var ddl = $(this);
                    var current = ddl.val();
                    ddl.empty().append('<option value="">Select</option>');
                    $.each(data, function (_, item) {
                        ddl.append($('<option/>', { value: item.ServiceTypeID, text: item.ServiceName }));
                    });
                    ddl.val(current);
                });
            });
        }

        $('#addRow').on('click', function () {
            $('#serviceBody').append(buildRow());
        });

        $(document).on('click', '.removeRow', function () {
            $(this).closest('tr').find('.isDeleted').val('true');
            $(this).closest('tr').remove();
            updateTotals();
        });

        $('#projectSelect').on('change', function () {
            loadServicesForProject();
        });

        $('#loadPrevious').on('click', function () {
            var projectId = $('#projectSelect').val();
            if (!projectId) {
                alert('Select a project first.');
                return;
            }

            $.getJSON('@Url.Action("GetPreviousSOEEData", "SOEE")', { projectId: projectId }, function (data) {
                if (!data.found) {
                    alert('No previous SOEE found for this project.');
                    return;
                }

                $('#PrevSOEEID').val(data.soeeId);
                $('#PreviousSOEEBalance').val(data.previousBalance);
                $('#previousSoeeLabel').text(data.soeeId);
                $('#previousBalanceLabel').text(parseFloat(data.previousBalance).toFixed(2));
                $('#ReferenceNo').val(data.referenceNo);
                $('#Subject').val(data.subject);
                $('#Reference').val(data.reference);
                $('#Content').val(data.content);
                $('#MarkTo').val(data.markTo);

                $('#serviceBody').empty();
                $.each(data.items, function (_, item) {
                    $('#serviceBody').append(buildRow(item));
                });

                bindRowEvents();
                $('#serviceBody tr').each(function () { calculateRow($(this)); });
            });
        });

        $(function () {
            bindRowEvents();
            $('#serviceBody').append(buildRow());
        });
    </script>
}
